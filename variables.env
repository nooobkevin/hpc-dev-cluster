# ============================================================
# hpc-dev-cluster — shared variables
# ============================================================
# Edit this file to customise the cluster for your environment.
# All paths are Windows-style; WSL will translate them via /mnt/c.

# --- VMware Workstation ---
VMWARE_BIN="/mnt/c/Program Files (x86)/VMware/VMware Workstation"
VMRUN="${VMWARE_BIN}/vmrun.exe"
VDISKMANAGER="${VMWARE_BIN}/vmware-vdiskmanager.exe"

# --- VM root on Windows filesystem ---
VM_BASE="C:\\Users\\nooob\\Documents\\Virtual Machines"
VM_BASE_WSL="/mnt/c/Users/nooob/Documents/Virtual Machines"

# --- ISO ---
ISO_PATH="C:\\Users\\nooob\\Downloads\\ISO\\Rocky-10.1-x86_64-boot.iso"
ISO_URL="https://download.rockylinux.org/pub/rocky/10/isos/x86_64/Rocky-10.1-x86_64-boot.iso"
ISO_LOCAL="/mnt/c/Users/nooob/Downloads/ISO/Rocky-10.1-x86_64-boot.iso"

# --- LAN Segment (hpc-lan) ---
# All cluster NICs on the internal network share this pvnID.
# Do NOT change after VMs are created — VMware uses it to wire the segment.
HPC_LAN_PVNID="52 02 60 b4 b8 41 35 a3-55 e1 a2 3c 4f 11 d2 8c"

# --- Cluster network (head NIC2 / Warewulf provision network) ---
HPC_LAN_SUBNET="192.168.100.0/24"
HEAD_LAN_IP="192.168.100.1"

# --- Node list ---
NODES="hpc-dev-cpu01 hpc-dev-cpu02"
