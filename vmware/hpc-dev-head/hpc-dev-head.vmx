.encoding = "UTF-8"
config.version = "8"
virtualHW.version = "21"
displayName = "hpc-dev-head"
guestOS = "rhel9-64"

# CPU
numvcpus = "2"
cpuid.coresPerSocket = "2"

# RAM
memsize = "8192"

# Firmware / Boot
firmware = "efi"
bios.bootDelay = "3000"

# SCSI Controller
scsi0.present = "TRUE"
scsi0.virtualDev = "lsilogic"

# HDD 160GB
scsi0:0.present = "TRUE"
scsi0:0.fileName = "hpc-dev-head.vmdk"
scsi0:0.deviceType = "scsi-hardDisk"

# CD-ROM (boot ISO) - remove after OS installation
ide1:0.present = "TRUE"
ide1:0.fileName = "C:\Users\nooob\Downloads\ISO\Rocky-10.1-x86_64-boot.iso"
ide1:0.deviceType = "cdrom-image"
ide1:0.startConnected = "TRUE"

# NIC 1 - Bridged (campus network, firewall: SSH/HTTP/HTTPS only)
ethernet0.present = "TRUE"
ethernet0.connectionType = "bridged"
ethernet0.virtualDev = "vmxnet3"
ethernet0.wakeOnPcktRcv = "FALSE"
ethernet0.addressType = "generated"

# NIC 2 - LAN Segment (hpc-lan, internal cluster network)
# pvnID shared across all cluster VMs to place them on the same LAN segment
ethernet1.present = "TRUE"
ethernet1.connectionType = "pvn"
ethernet1.pvnID = "52 02 60 b4 b8 41 35 a3-55 e1 a2 3c 4f 11 d2 8c"
ethernet1.virtualDev = "vmxnet3"
ethernet1.wakeOnPcktRcv = "FALSE"
ethernet1.addressType = "generated"

# USB
usb.present = "TRUE"
usb_xhci.present = "TRUE"

# Sound (disabled)
sound.present = "FALSE"

# Misc
tools.syncTime = "FALSE"
powerType.powerOff = "soft"
powerType.reset = "soft"
powerType.suspend = "soft"
